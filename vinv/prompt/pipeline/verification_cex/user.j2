fn append_while1(v: &Vec<u64>, elem: u64)
    let mut c = Vec::with_capacity(v.len() + 1);
    let mut n: usize = 0;
    let len: usize = v.len();

    assume(n != len);
    assume(v.len() == len);
    assume(n >= 0);
    assume(n < len + 1);
    // Note: assume(c.len() == n) is missing.
    assume(forall|i: int| (0 <= i && i < n) ==> c[i] == v[i]);

    c.push(v[n]);
    n = n + 1;

    assert(v.len() == len);
    assert(n >= 0);
    assert(n < len + 1);
    assert(forall|i: int| (0 <= i && i < n) ==> c[i] == v[i]);
